---
import type { $brand } from "astro:schema";
import "../styles/global.css";

const projects = [
  {
    name: "Final Grade Calculator",
    desc: "Because rogerhub's is ugly.",
    href: "https://final.danielx.link",
  },
  {
    name: "RxLog",
    desc: "Because a medication logger shouldn't require a master's in computer science.",
    href: "https://rxlog.danielx.link",
  },
  {
    name: "ScheduleSync",
    desc: "Because those five minutes spent copying your class schedule to Google Calendar could be better spent doing something else.",
    href: "https://schedulesync.tech",
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <title>Doohickey Labs</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;1,6..72,400&family=Outfit:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main>
      <h1>Doohickey Labs</h1>
      <p class="subtitle">
        <a class="subtitle-link" href="https://danielx.me" target="_blank"
          >Daniel's</a
        > ... company? Who knows what the future holds. I make stuff.
        <ul>
          {
            projects.map((p) => (
              <li>
                <a href={p.href} target="_blank">
                  <span class="name">{p.name}</span>
                  <span class="desc">{p.desc}</span>
                  <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M7 17 17 7m0 0H7m10 0v10" />
                  </svg>
                </a>
              </li>
            ))
          }
        </ul>
      </p>
    </main>
  </body>

  <style>
    body {
      margin: 0;
      background: #0c0c0c;
      background-image:
        linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
      background-size: 40px 40px;
      color: #e8e4df;
      font-family: "Outfit", sans-serif;
      font-weight: 300;
      min-height: 100dvh;
      -webkit-font-smoothing: antialiased;
    }

    main {
      max-width: 540px;
      margin: 0 auto;
      padding: 20vh 1.5rem 4rem;
    }

    h1 {
      font-family: "Newsreader", serif;
      font-size: clamp(2.4rem, 7vw, 3.6rem);
      font-weight: 400;
      font-style: italic;
      letter-spacing: -0.03em;
      margin: 0;
      line-height: 1.05;
      color: #f5f2ed;
    }

    .subtitle {
      font-size: 0.85rem;
      color: #7a756f;
      letter-spacing: 0.04em;
      margin: 0.75rem 0 3rem;
    }

    .subtitle-link {
      display: inline;
      padding: 0;
      color: #a09890;
      text-decoration-line: underline;
      text-decoration-color: rgba(160, 152, 144, 0.3);
      text-underline-offset: 2px;
    }

    .subtitle-link:hover {
      color: #e8e4df;
      text-decoration-color: rgba(232, 228, 223, 0.5);
    }

    ul {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
    }

    li {
      border-top: 1px solid rgba(255, 255, 255, 0.08);
    }

    li:last-child {
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    a {
      display: flex;
      align-items: baseline;
      gap: 1rem;
      padding: 1.25rem 0;
      text-decoration: none;
      color: inherit;
      transition: color 0.2s;
    }

    a:hover {
      color: #fff;
    }

    a:hover svg {
      opacity: 1;
      transform: translate(2px, -2px);
    }

    a:focus-visible {
      outline: 1px solid #fff;
      outline-offset: 8px;
    }

    .name {
      font-family: "Newsreader", serif;
      font-size: 1.2rem;
      font-weight: 500;
      letter-spacing: -0.01em;
      flex-shrink: 0;
    }

    .desc {
      font-size: 0.85rem;
      color: #6b6560;
      flex: 1;
      min-width: 0;
    }

    svg {
      flex-shrink: 0;
      opacity: 0.3;
      transition: all 0.2s;
      align-self: center;
    }

    @media (max-width: 500px) {
      a {
        display: grid;
        grid-template-columns: 1fr auto;
        grid-template-rows: auto auto;
        gap: 0.25rem;
        align-items: center;
      }

      .name {
        grid-column: 1;
        grid-row: 1;
      }

      svg {
        grid-column: 2;
        grid-row: 1;
      }

      .desc {
        grid-column: 1 / -1;
        grid-row: 2;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      a,
      svg {
        transition: none;
      }
    }
  </style>
</html>
